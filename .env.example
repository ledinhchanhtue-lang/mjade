# MJADE — biến môi trường
#
# Cả ba biến dưới đây là URL webhook nhận dữ liệu form dạng JSON (POST).
# Có thể dùng: Zapier / Make.com webhook, Google Apps Script, Slack incoming
# webhook qua proxy, hoặc endpoint backend riêng.
#
# Khi CHƯA cấu hình: form vẫn hoạt động — dữ liệu được ghi vào server log
# (Vercel Functions log) với prefix [MJADE:consult] / [MJADE:newsletter] /
# [MJADE:reserve] để không mất liên hệ của khách. Nên cấu hình webhook thật
# trước khi chạy chiến dịch.

# Nhận đăng ký tư vấn từ /lien-he-tu-van
CONSULT_WEBHOOK_URL=

# Nhận email đăng ký nhận tin từ footer
NEWSLETTER_WEBHOOK_URL=

# Nhận yêu cầu đặt giữ sản phẩm từ /gio-hang
RESERVE_WEBHOOK_URL=

# URL gốc của website (dùng cho sitemap/metadata khi đổi tên miền)
NEXT_PUBLIC_SITE_URL=https://mjade.vercel.app

# ------------------------------------------------------------------
# TRANG QUẢN TRỊ /admin
# ------------------------------------------------------------------
# Mật khẩu đăng nhập /admin. BẮT BUỘC phải đặt thì trang quản trị mới bật.
# Tự chọn một mật khẩu mạnh; không dùng lại mật khẩu của dịch vụ khác.
ADMIN_PASSWORD=

# Ghi thay đổi trở lại GitHub (Git-based CMS) — sau khi lưu, Vercel tự deploy lại.
# GITHUB_TOKEN: GitHub → Settings → Developer settings → Personal access tokens →
#   Fine-grained token, chỉ chọn repo mjade, quyền "Contents: Read and write".
GITHUB_TOKEN=
GITHUB_REPO=ledinhchanhtue-lang/mjade
GITHUB_BRANCH=main
